# Cloudflare R2 settings for Restic's S3 backend.
# Copy this file to .env and fill in the real values.

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=your-r2-bucket-name
R2_PREFIX=codex/history

R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_REGION=auto

# Optional override. If set, this takes precedence over R2_ACCOUNT_ID/R2_BUCKET/R2_PREFIX.
# RESTIC_REPOSITORY=s3:https://your-account-id.r2.cloudflarestorage.com/your-r2-bucket-name/codex/history
