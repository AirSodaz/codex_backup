# Optional Restic repository settings.
# Copy this file to .env only when you want to override the default local repository.
#
# If RESTIC_REPOSITORY is not set, codex-backup uses its platform app data
# directory as a local Restic repository.

# Use an explicit local Restic repository:
# RESTIC_REPOSITORY=C:\Users\you\codex-restic-repository

# Or use any Restic-supported repository URL, such as Cloudflare R2 through S3:
# RESTIC_REPOSITORY=s3:https://your-account-id.r2.cloudflarestorage.com/your-r2-bucket-name/codex/history
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_REGION=auto

# Legacy R2 fields are still supported. When RESTIC_REPOSITORY is not set,
# these values are used to build the s3: repository URL.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_BUCKET=your-r2-bucket-name
# R2_PREFIX=codex/history
